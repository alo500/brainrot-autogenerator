# ─── Anthropic (script + series generation) ──────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── Kling AI ────────────────────────────────────────────
KLING_ACCESS_KEY=your_kling_access_key
KLING_SECRET_KEY=your_kling_secret_key

# ─── Upstash Redis (queue) ───────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# ─── Supabase ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Cloudflare R2 ───────────────────────────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=brainrot-videos
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ─── Local Wan2.1 server ─────────────────────────────────
# Set this to your Cloudflare Tunnel URL when running locally
WAN_SERVER_URL=http://localhost:8000

# ─── Worker auth ─────────────────────────────────────────
WORKER_SECRET=change_this_to_a_random_secret
